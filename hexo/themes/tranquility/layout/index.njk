{% extends "_partials/layout.njk" %}
{% block link %}
  {% if theme.baidu_site_verification %}
    <meta name="baidu-site-verification"
          content="{{ theme.baidu_site_verification }}"/>
  {% endif %}
  <link rel="stylesheet"
        type="text/css"
        href='{{ url_for("/css/index.css") }}'/>
{% endblock link %}
{% block body %}
  <div class="wall wall-index">
    <div class="wall-main" id="wall-main">
      <div class="wall-title">{{ config.title | upper }}</div>
      <div class="wall-subtitle">{{ config.subtitle }}</div>
      <div class="wall-description">{{ theme.slogan }}</div>
    </div>
    <div class="wall-bg">
      <div class="wall-bg-index">
        <div class="ai-terminal">
          <div class="ai-terminal-bar">
            <span></span><span></span><span></span>
          </div>
          <div class="ai-terminal-body">
            <div class="ai-terminal-line">
              <span class="ai-terminal-tag user">You</span>
              <span>探索 AI 的边界</span>
            </div>
            <div class="ai-terminal-line">
              <span class="ai-terminal-tag ai">AI</span>
              <span id="ai-typing-text"></span>
              <span class="ai-terminal-cursor"></span>
            </div>
          </div>
        </div>
        <div class="ai-formula">
          <div class="ai-formula-tag">Neural Network</div>
          <div class="ai-formula-main">
            <span class="ai-formula-fn">σ</span>
            <span class="ai-formula-arg">(</span>
            <span class="ai-formula-var">W</span>
            <span class="ai-formula-arg">·</span>
            <span class="ai-formula-var">x</span>
            <span class="ai-formula-arg"> + </span>
            <span class="ai-formula-var">b</span>
            <span class="ai-formula-arg">)</span>
          </div>
          <div class="ai-formula-desc">前向传播 · Forward Pass</div>
        </div>
        <canvas width="400" height="400" id="ai-network"></canvas>
        <div class="motto">{{ theme.index.motto }}</div>
        <div class="poem">
          {% for line in theme.index.poem %}
            {{ line }}
            <br/>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
  <div class="about">
    <div class="about-photo"
         style="background-image: url({{ url_for(theme.index.photo) }})"></div>
    <div class="about-text">
      <div class="about-title">
        {% for word in theme.index.about.title %}
          <div class="matts">{{ word }}</div>
        {% endfor %}
      </div>
      <div class="about-detail">
        <div class="about-text-p">
          {% for line in theme.index.about.text %}
            {% if not line %}
              <br/>
            {% else %}
              {{ line }}
              <br/>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
  {% if theme.timeline and theme.timeline.enable %}
    <div class="timeline">
      <div class="timeline-head">
        <div class="title">生命周期</div>
        <div class="radio-wrapper">
          {% for item in theme.timeline.items %}
            <div class="radio">
              <input id="radio-{{ item.name }}"
                     type="checkbox"
                     {% if item.checked %}checked{% endif %}/>
              <label class="radio-skin--{{ item.name }}" for="radio-{{ item.name }}"></label>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="timeline-body">
        <div class="timeline-item-first">
          <div class="line-anchor line-anchor--now"></div>
        </div>
        <div class="timeline-list" id="timeline-list"></div>
        <div class="timeline-item-last">
          <div class="line-anchor line-anchor--end"></div>
        </div>
      </div>
    </div>
  {% endif %}
{% endblock body %}
{% block script %}
  {% include "_partials/scripts/NeuralNet.njk" %}
  {% include "_partials/scripts/AiTerminal.njk" %}
  {% from "_partials/scripts/Timeline.njk" import timeline %}
  {% if theme.timeline and theme.timeline.enable %}{{ timeline(site.timelineData) }}
  {% endif %}
{% endblock script %}